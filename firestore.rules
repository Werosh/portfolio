// Publish to Firebase: Firebase Console → Firestore → Rules → paste → Publish
// Or from repo root (after `firebase login`): npm run deploy:firestore-rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }
  }
}
