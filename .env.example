VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# EmailJS - contact form sends a copy to your inbox (https://www.emailjs.com/).
# HTML paste template: email-templates/emailjs-contact-portfolio.html
# Use Public Key (not private). Account → API keys → Authorized domains: add http://localhost:5173 + your live origin.
# Create a template with To Email = your address; variables: {{from_name}}, {{reply_to}}, {{message}}
VITE_EMAILJS_PUBLIC_KEY=
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
# Shown on the landing page contact block (mailto + visible address).
VITE_PUBLIC_CONTACT_EMAIL=

# npm run seed:projects (email/password path only - NOT used by the control-center UI).
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=

# One-time: npm run seed:projects - upserts portfolio rows (needs rules published OR service account below).
# If seed fails with PERMISSION_DENIED: publish firestore.rules in Console, or run npm run deploy:firestore-rules, or set:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
