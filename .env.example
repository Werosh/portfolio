VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional: pre-fills the /control-center login form (local dev only).
# WARNING: Vite inlines VITE_* into the client bundle - anyone can read these values.
# Do not use a real production password here.
VITE_ADMIN_EMAIL=
VITE_ADMIN_PASSWORD=

# One-time: npm run seed:projects - upserts portfolio rows (needs rules published OR service account below).
# If seed fails with PERMISSION_DENIED: publish firestore.rules in Console, or run npm run deploy:firestore-rules, or set:
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccount.json
